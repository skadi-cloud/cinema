<idea-plugin>
    <id>cloud.skadi.ide.plugin</id>
    <name>Skadi Cloud</name>
    <vendor email="kolja@hey.com" url="https://skadi.cloud">Skadi Cloud</vendor>

    <description><![CDATA[
    Enter short description for your plugin here.<br>
    <em>most HTML tags may be used</em>
    ]]></description>

    <!-- please see https://www.jetbrains.org/intellij/sdk/docs/basics/getting_started/plugin_compatibility.html
         on how to target different products -->
    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <preloadingActivity implementation="cloud.skadi.ide.plugin.SkadiInit"/>
        <applicationService serviceInterface="cloud.skadi.ide.plugin.SkadiHeartbeatService"
                        serviceImplementation="cloud.skadi.ide.plugin.impl.SkadiHeartbeatServiceImpl"/>
        <applicationService serviceInterface="cloud.skadi.ide.plugin.SkadiCloudTasksService"
                        serviceImplementation="cloud.skadi.ide.plugin.impl.SkadiCloudTasksServiceImpl"/>
    </extensions>


    <actions>
        <!-- Add your actions here -->
        <action id="cloud.skadi.ide.plugin.CommunitySamplesAction" class="cloud.skadi.ide.plugin.CommunitySamplesAction"
                text="Community Samples" description="Installs the Community F Samples"
        >
            <add-to-group group-id="WelcomeScreen.QuickStart" anchor="last"/>
        </action>

        <action id="cloud.skadi.ide.plugin.feedback" class="cloud.skadi.ide.plugin.FeedbackAction"
                text="Skadi Cloud: Feedback">
            <add-to-group group-id="HelpMenu" anchor="before" relative-to-action="ReportProblem"/>
        </action>
    </actions>
</idea-plugin>